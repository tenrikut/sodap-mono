{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node", // ← no more error
    "lib": ["es2020"],
    "types": ["node", "mocha", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true // allowed again
  }
}
